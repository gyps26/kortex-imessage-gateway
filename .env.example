# Public URL of this gateway (used for OAuth callbacks, worker URLs, webhooks)
APP_URL="http://localhost:3000"

# MongoDB Connection String
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/kortex-imessage-gateway"

# Redis URL for BullMQ message queue
REDIS_URL="redis://default:password@localhost:6379"

# Secret required to authenticate Mac workers (CLI + Electron app)
API_SECRET="my_super_secret_for_mac_workers"

# Optional: protect sensitive settings API routes
ADMIN_API_KEY="your_admin_api_key_here"

# GoHighLevel OAuth — server-side (token exchange)
GHL_CLIENT_ID="your_ghl_client_id"
GHL_CLIENT_SECRET="your_ghl_client_secret"

# GoHighLevel OAuth — client-side (Connect button in browser)
NEXT_PUBLIC_GHL_CLIENT_ID="your_ghl_client_id"
NEXT_PUBLIC_GHL_REDIRECT_URI="http://localhost:3000/api/oauth"

# Optional: verify inbound GHL webhooks (Authorization header or x-ghl-webhook-secret)
GHL_WEBHOOK_SECRET="ghl_webhook_secret_here"

# Firebase Admin SDK (required for Android SMS FCM outbound)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# WhatsApp worker debug logging
WASP_DEBUG="false"
