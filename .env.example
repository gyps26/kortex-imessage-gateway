# =============================================================================
# Kortex iMessage Gateway — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Required: Core ---
# Public URL of this gateway (OAuth callbacks, worker URLs, webhooks)
APP_URL="http://localhost:3000"

# MongoDB connection string
MONGODB_URI="mongodb://localhost:27017/kortex-imessage-gateway"

# Redis URL — REQUIRED for WhatsApp worker and message queues
# Without Redis, WhatsApp QR codes will not generate and outbound queuing is disabled
REDIS_URL="redis://localhost:6379"

# Secret for Mac iMessage workers (CLI + Electron app)
API_SECRET="my_super_secret_for_mac_workers"

# --- Optional: Admin protection ---
# When set, /api/settings/* routes require Authorization: Bearer <key> or x-admin-key header
ADMIN_API_KEY="your_admin_api_key_here"

# --- GoHighLevel OAuth ---
GHL_CLIENT_ID="your_ghl_client_id"
GHL_CLIENT_SECRET="your_ghl_client_secret"
NEXT_PUBLIC_GHL_CLIENT_ID="your_ghl_client_id"
NEXT_PUBLIC_GHL_REDIRECT_URI="http://localhost:3000/api/oauth"

# Optional: verify inbound GHL webhooks
GHL_WEBHOOK_SECRET="ghl_webhook_secret_here"

# --- Android SMS (Firebase Admin SDK) ---
# REQUIRED for sending outbound SMS via FCM push to Android devices
# Without these, inbound SMS still works but outbound will fail
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- WhatsApp worker ---
# Set to "true" for verbose WaSP/Baileys debug logs
WASP_DEBUG="false"

# =============================================================================
# How to run everything:
#
#   Option A (recommended):  docker compose up
#     Starts web + whatsapp-worker + MongoDB + Redis together
#
#   Option B (local dev):    npm run dev:all
#     Starts Next.js dev server + WhatsApp worker in one command
#
#   Option C (manual):       npm run dev  (terminal 1)
#                            npm run worker:whatsapp  (terminal 2)
# =============================================================================
